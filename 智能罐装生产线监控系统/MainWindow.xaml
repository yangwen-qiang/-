<Window x:Class="智能罐装生产线监控系统.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:UserControl="clr-namespace:智能罐装生产线监控系统.UserControls"
        xmlns:local="clr-namespace:智能罐装生产线监控系统"
        mc:Ignorable="d"
        Title="智能罐装" Height="450" Width="800" >
   
    <Grid Background="{StaticResource AppBgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <UserControl:NavigationMenu Grid.RowSpan="2" />
        <ContentControl Grid.Row="1" Grid.Column="1" Margin="20" Content="{Binding UserControl}" Background="{StaticResource AppBgDark}"/>
    </Grid>
</Window>
