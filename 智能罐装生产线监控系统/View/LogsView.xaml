<UserControl x:Class="智能罐装生产线监控系统.View.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:智能罐装生产线监控系统.View"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="900">
    <Grid>
        <TabControl Style="{StaticResource TabControlContext}">
            <TabItem Header="Logs" Style="{StaticResource TabItem11}" IsSelected="True" >
                <ContentControl />
            </TabItem>
            <TabItem Header="LogAnalyze" Style="{StaticResource TabItem11}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition />
                        <RowDefinition  Height="auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource AppBgDark}" CornerRadius="4" Padding="8" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="从:" Margin="0,0,5,0" Foreground="White" VerticalAlignment="Center"/>
                            <hc:DateTimePicker SelectedDateTime="{Binding StartDate}"  VerticalAlignment="Center" Width="120"/>
                            <TextBlock Text="到:" Margin="10,0,5,0" Foreground="White" VerticalAlignment="Center"/>
                            <hc:DateTimePicker SelectedDateTime="{Binding StartDate}"  VerticalAlignment="Center" Width="120"/>
                            <TextBlock Text="等级:" Margin="10,0,0,5" VerticalAlignment="Center" Foreground="White"/>
                            <ComboBox ItemsSource="{Binding Levels}" SelectedItem="{Binding SelelctLevel}" VerticalAlignment="Center" Width="120"/>
                            <TextBlock Text="搜索" Margin="10,0,5,5" VerticalAlignment="Center" Foreground="White"/>
                            <TextBox VerticalAlignment="Center" Width="150" Margin="10,0,10,0"/>
                            <Button Content="查询"  Margin="5,0,10,0"/>
                            <Button Content="导出Csv"  Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <DataGrid Grid.Row="1">
                        
                    </DataGrid>
                    <Border Grid.Row="2" Background="Transparent">
                        <Grid>
                            <TextBlock Text="正在查询" Foreground="LimeGreen" FontSize="14" VerticalAlignment="Center" Margin="5" HorizontalAlignment="Left"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5,10,5" Orientation="Horizontal">
                                <TextBlock Text="{Binding TotalCount,StringFormat='共{0}条记录'}" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray"/>
                                <Button Content="上一页" VerticalAlignment="Center" Width="80" Foreground="White" Background="{StaticResource AppBgDark}"/>
                                <TextBlock Text="{Binding PageIndex,StringFormat='第{0}页'}" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray"/>
                                <Button Content="下一页" VerticalAlignment="Center" Width="80" Foreground="White" Background="{StaticResource AppBgDark}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
