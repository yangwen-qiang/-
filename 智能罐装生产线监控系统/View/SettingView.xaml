<UserControl x:Class="智能罐装生产线监控系统.View.SettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:智能罐装生产线监控系统.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <StackPanel Margin="20" Width="800" HorizontalAlignment="Left">
        <Border Margin="0,10,0,0" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="串口设置" FontSize="14"  Foreground="{StaticResource AppDanger}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="串口号" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="White"/>
                    <ComboBox  Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"  ItemsSource="{Binding PortNames}" SelectedValue="{Binding PortName}" />
                    <TextBlock Text="波特率" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Margin="0,8,0,0"/>
                    <ComboBox  Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"  ItemsSource="{Binding BaudRates}" SelectedValue="{Binding SelectedBauds}" Margin="0,8,0,0" />
                    <TextBlock Text="数据位" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Margin="0,8,0,0"/>
                    <ComboBox  Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"  ItemsSource="{Binding DataBitOptions}" SelectedValue="{Binding SelectedDataBits}" Margin="0,8,0,0" />
                    <TextBlock Text="校验位" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Foreground="White" Margin="0,8,0,0"/>
                    <ComboBox  Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"  ItemsSource="{Binding ParityOptions}" SelectedValue="{Binding SelectedParity}" Margin="0,8,0,0"/>
                    <TextBlock Text="停止位" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="White"/>
                    <ComboBox  Grid.Row="4" Grid.Column="1" VerticalAlignment="Center"  ItemsSource="{Binding StopOptions}" SelectedValue="{Binding SelectedStopBits}" Margin="0,8,0,0"/>
                </Grid>
                <Button Content="保存配置" Command="{Binding SaveCommand}" HorizontalAlignment="Left" Height="40" Width="120" Background="Aqua" Margin="7,5,0,0"/>
            </StackPanel>
           
        </Border>
        <Border Style="{StaticResource CardStyle}" Margin="0,20,0,0">
            <StackPanel>
                <TextBlock Text="登录选项" Foreground="White" FontSize="14" Margin="0,0,0,10"/>
                <CheckBox Content="启动时自动连接设备" IsChecked="{Binding AutoConnect}"  Foreground="{StaticResource AppTextMuted}"  Cursor="Hand"/>
                <CheckBox Content="开启报警声音提示" IsChecked="{Binding AlarmSound}"  Foreground="{StaticResource AppTextMuted}" Cursor="Hand" />
                <CheckBox Content="开启日志调试" IsChecked="{Binding DebugLogMode}" Foreground="{StaticResource AppTextMuted}" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
